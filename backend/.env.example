# MiniMax 开放平台 (配音 TTS + 结构化场景提示词用的 LLM)
# 国际站用 https://api.minimax.io ，中国大陆账号用 https://api.minimaxi.com
MINIMAX_API_HOST=https://api.minimaxi.com
MINIMAX_API_KEY=
MINIMAX_TEXT_MODEL=MiniMax-M2.5

# 火山引擎方舟(Ark) 豆包·Seedream 文生图
# 在火山引擎控制台 > 火山方舟 > API Key管理 里创建
# ARK_IMAGE_MODEL 默认用模型名直接调用；如果账号是"推理接入点"模式，
# 换成控制台里创建的接入点ID（形如 ep-20250xxxxxxxxx-xxxxx）
ARK_API_KEY=
ARK_IMAGE_MODEL=doubao-seedream-4-5-251128

# Google Gemini (官方直连)：画风选 gemini 时，生图和配音都走它，自己闭环
# 在 https://aistudio.google.com/apikey 创建
# 注：不要随手把 GEMINI_IMAGE_MODEL 换成 gemini-3.1-flash-image，
#     实测它偏写实、画面里的英文反而会拼错（如 IMBALANCE -> IMBALACE）
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts

# OpenRouter：代理同一个 gemini-2.5-flash-image 生图
# 在 https://openrouter.ai/keys 创建
# 它上面没有可用的 TTS（只有音乐生成和对话式语音），所以选 openrouter 时配音会回落到 MiniMax
OPENROUTER_API_KEY=
OPENROUTER_IMAGE_MODEL=google/gemini-2.5-flash-image

# 阿里云 DashScope (通义万相文生图，备用适配器，当前未启用)
DASHSCOPE_API_KEY=

# 字幕字体（本机 Windows 字体文件路径，当前仅 probe 脚本历史遗留用途）
CAPTION_FONT_PATH=C:/Windows/Fonts/msyhbd.ttc

# 剪映草稿文件夹：打开剪映App -> 全局设置 -> 草稿位置，把那里显示的路径填进来
# （下面这个是Windows默认安装路径，没改过草稿位置的话通常不用改）
JIANYING_DRAFTS_DIR=C:\Users\你的用户名\AppData\Local\JianyingPro\User Data\Projects\com.lveditor.draft
CANVAS_WIDTH=1080
CANVAS_HEIGHT=1920

# 本地资源存储目录（相对 backend/ 目录）
STORAGE_DIR=storage
